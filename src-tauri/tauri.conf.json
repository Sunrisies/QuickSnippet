{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickKit",
  "version": "0.1.1",
  "identifier": "com.hover.quickkit",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuickKit - 快捷工具箱",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}