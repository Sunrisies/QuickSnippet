{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "quicklaunch", "region_selector", "recording_frame", "splash"],
  "permissions": [
    "core:default",
    "core:event:default",
    "opener:default",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-open",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
